<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Pomodorre.WinUI.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Pomodorre.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:stats="using:Pomodorre.Statistics"
    xmlns:conv="using:Pomodorre.Converters"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MaxWidth="1200" Padding="50,0,50,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Margin="0,0,0,20" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource DisplayTextBlockStyle}" FontSize="30">Session history</TextBlock>
            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10">
                <Button Click="PreviousWeek_Click">← Previous</Button>
                <TextBlock VerticalAlignment="Center" FontSize="14">
                    <Run Text="{x:Bind FormatWeekRange(handler.WeekStart, handler.WeekEnd), Mode=OneWay}"/>
                </TextBlock>
                <Button Click="NextWeek_Click" IsEnabled="{x:Bind handler.CanNavigateNext, Mode=OneWay}">Next →</Button>
            </StackPanel>
        </Grid>
        <ListView ItemsSource="{x:Bind handler}" SelectionMode="Single" Grid.Row="1" Grid.Column="0">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">Duration</TextBlock>
                                    <TextBlock FontSize="16" FontWeight="SemiBold">
                                        <Run Text="{Binding FocusMinutes}"/>
                                        <Run Text="m"/>
                                    </TextBlock>
                                </StackPanel>
                                <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,0"/>
                                <StackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">Break</TextBlock>
                                    <TextBlock FontSize="16" FontWeight="SemiBold">
                                        <Run Text="{Binding BreakMinutes}"/>
                                        <Run Text="m"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">Started</TextBlock>
                                <TextBlock FontSize="13">
                                    <Run Text="{Binding StartedAtUtc}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Grid.Column="1" Margin="16,0,0,0" Spacing="8" VerticalAlignment="Center">
                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">Total Focus</TextBlock>
                                <TextBlock FontSize="14" FontWeight="SemiBold">
                                    <Run Text="{Binding FocusMinutes}"/>
                                    <Run Text="min"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Grid.Column="2" Margin="16,0,0,0" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,4">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}">
                                    <Run Text="{Binding Status}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Grid.Column="1" Grid.Row="1" Margin="20,0,0,0" Spacing="10">
        </StackPanel>

        <ProgressRing IsActive="{x:Bind handler.IsLoading, Mode=OneWay}" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</Page>
